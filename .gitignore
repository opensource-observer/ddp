.venv/
__pycache__/
*.py[cod]

# --- Environment variables ---
.env
.env.local
app/.env.*

# --- Next.js (app/) ---
app/.next/
app/out/
app/node_modules/
app/public/notebooks/
app/public/data/

# --- OS ---
.DS_Store

# --- Claude Code (local settings) ---
.claude/
.mcp.json
.playwright-mcp/

# --- Editor / IDE ---
.vscode/
